{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": [
    "iad1"
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    },
    {
      "source": "/((?!_next/static|_next/image|favicon\\.ico).*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/ingest",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/rss",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/collect-news",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/collect-flights",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/collect-vessels",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/collect-seismic",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/collect-fires",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/collect-outages",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/enrich-events",
      "schedule": "*/3 * * * *"
    },
    {
      "path": "/api/cron/generate-embeddings",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/cluster-events",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/correlate",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/detect-patterns",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/calculate-risk-scores",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/generate-predictions",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/evaluate-predictions",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/evaluate-alerts",
      "schedule": "*/3 * * * *"
    },
    {
      "path": "/api/cron/send-alerts",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/flash-report",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/calculate-flywheel",
      "schedule": "0 */4 * * *"
    },
    {
      "path": "/api/cron/generate-daily-brief",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/generate-weekly-summary",
      "schedule": "0 6 * * 1"
    },
    {
      "path": "/api/cron/source-credibility",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/cleanup",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/collect-commodity-prices",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/detect-market-correlations",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/sync-sanctions",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/update-country-profiles",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/check-personnel-safety",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/check-supply-chain",
      "schedule": "*/15 * * * *"
    }
  ]
}